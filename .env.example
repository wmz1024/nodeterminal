# ==================== OpenID Connect ====================
# Set OIDC_ENABLED=true to enable OpenID Connect login
OIDC_ENABLED=false

# OIDC provider discovery URL (e.g. https://accounts.google.com)
OIDC_ISSUER=https://accounts.google.com

# OIDC Client credentials (from your OIDC provider)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Callback URL - must match the redirect URI registered in your OIDC provider
OIDC_REDIRECT_URI=http://localhost:3000/api/oidc/callback

# Scopes to request (space-separated)
OIDC_SCOPES=openid profile email

# Button label shown in the login dialog
OIDC_BUTTON_LABEL=OpenID 登录
